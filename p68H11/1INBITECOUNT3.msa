    p68H11
    ORG $2000
    ldaa    #11111111b   ponemos el bit 
    staa    %60 lo guardo en el 60
    clra        se cleariza a
    ldaa    #8
    staa    %64 guardamos la cantidad de bucle
    clra
    ldab    #00000001b   ponemos la mask
    ldx     #$3000
    stab    1,X
bucle       ldaa    %60 buscamos el valor de A
    anda    1,X hacemos and con la mascara
    bne     ifuno   saltamos si hay 1 en el bit
    bra     sigue   entonces seguimos
ifuno       iny     sumamos 1 al contador
sigue       lslb    movemos la mask un bit
    inx             sumamos uno al pointer
    stab    1,X     ponemos el siguiente BIT de la mask
    dec     %64     decrementamos el contador
    bne     bucle   si terminamos saltamos    
fin jmp     fin
    END
